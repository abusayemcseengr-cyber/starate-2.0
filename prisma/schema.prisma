generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  avatar        String?
  ratings       Rating[]
  createdAt     DateTime  @default(now())
}

model Celebrity {
  id            String    @id @default(cuid())
  name          String
  photo         String
  bio           String
  category      String
  nationality   String?
  ratings       Rating[]
  avgRating     Float     @default(0)
  totalVotes    Int       @default(0)
}

model Rating {
  id            String    @id @default(cuid())
  score         Int
  user          User      @relation(fields: [userId], references: [id])
  userId        String
  celebrity     Celebrity @relation(fields: [celebrityId], references: [id])
  celebrityId   String
  createdAt     DateTime  @default(now())

  @@unique([userId, celebrityId])
}
