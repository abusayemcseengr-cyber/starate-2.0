# Copy to .env and set a strong secret (e.g. openssl rand -base64 32)
AUTH_SECRET=

# Vercel Postgres / Cloud Database variables
POSTGRES_PRISMA_URL="postgres://username:password@host/database_name?connection_limit=1"
POSTGRES_URL_NON_POOLING="postgres://username:password@host/database_name"

# The deployment URL for Auth routing and og images
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin panel secret PIN
ADMIN_SECRET="change-this-to-a-secure-pin"
